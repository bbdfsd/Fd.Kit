  },
  "Redis": {
    //"Configuration": "localhost,password=mypassword,defaultdatabase=1"
    "Configuration": "localhost,defaultdatabase=1"
  },
  "Jwt": {
    "Audience": "Fd.Kit.BasicManagement",
    "SecurityKey": "dzehzRz9a8asdfasfdadfasdfasdfafsdadfasbasdf=",
